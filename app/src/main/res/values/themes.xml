<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MyApplication" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/teal_200</item>

        <item name="android:buttonStyle">@style/MyButtonStyle</item>

        <item name="android:windowBackground">@color/white</item>

        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/dark_gray</item>
    </style>

    <style name="Theme.MyApplication.Dark" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/teal_200</item>

        <item name="android:buttonStyle">@style/MyButtonStyle.Dark</item>

        <item name="android:windowBackground">@color/black</item>

        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/light_gray</item>

        <item name="android:editTextColor">@color/white</item>
        <item name="android:textColorHint">@color/light_gray</item>
    </style>

    <style name="MyButtonStyle" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/purple_500</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="MyButtonStyle.Dark" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/purple_200</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="Theme.FullScreenImage" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="MyAlertDialogStyle" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorAccent">@color/purple_500</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:background">@color/white</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/MyDialogButtonStyle</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/MyDialogButtonStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/MyDialogButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/MyDialogButtonStyle</item>
    </style>

    <style name="MyAlertDialogStyle.Dark" parent="Theme.AppCompat.Dialog.Alert">
        <item name="colorAccent">@color/purple_200</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@color/dark_gray</item>
        <item name="android:windowBackground">@color/dark_gray</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/MyDialogButtonStyle.Dark</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/MyDialogButtonStyle.Dark</item>
        <item name="buttonBarPositiveButtonStyle">@style/MyDialogButtonStyle.Dark</item>
        <item name="buttonBarNegativeButtonStyle">@style/MyDialogButtonStyle.Dark</item>
    </style>

    <style name="MyDialogButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/purple_500</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="MyDialogButtonStyle.Dark" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/purple_200</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>